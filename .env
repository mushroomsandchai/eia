# Airflow and DBT shared variables
## TODO
LOCAL_GCS_JSON_CREDENTIALS_PATH=PATH_TO_JSON_KEY

# Dbt configuration variables
# The following environment variables will be used to create a profile instead of baking/copying profiles.yml file into the container
## TODO
PROJECT=PROJECT_ID                # GCS PROJECT ID
BUCKET_NAME=BUCKET_NAME           # GCP BUCKET NAME
DATASET=DATASET_NAME              # BQ Dataset name
DATASET_LOCATION=US               # BQ Dataset location

## TODO
# API KEY from Energy Information Authority (FREE FOR ALL).
# https://www.eia.gov/opendata/register.php
EIA_API=EIA_API_KEY


## TODO IN-CASE THE USER ID IS DIFFERENT
# Make sure to put your uid here. 
# To get your UID, run `id -u` in your terminal.
AIRFLOW_UID=1001

# DBT Paths
DBT_PROFILES_DIR=/opt/airflow/dbt/
DBT_PROJECT_PATH=/opt/airflow/dbt/
DBT_MANIFEST_PATH=/opt/airflow/dbt/target/manifest.json
DBT_VIRTUAL_ENVIRONMENT_PATH=/opt/airflow/.dbt_venv/bin/dbt
CONTAINER_JSON_CREDENTIALS_PATH=/.cred/
GOOGLE_APPLICATION_CREDENTIALS=/.cred/.cred.json

# By default the pipeline fetches fresh data for the last 7 days to account for late arriving data and updates by EIA.
# You can change the number of days by changing the following variable.
WINDOW_DAYS=7

# Airflow variables
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
PYTHONPATH=/opt/airflow/dags
